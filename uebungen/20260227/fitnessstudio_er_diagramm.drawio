        <mxCell id="Dk36MoI9mi1UDb7i2JSW-1" parent="1" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;div&gt;&lt;b&gt;# Aufgabe 4: Fitnessstudio-Verwaltung&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Ein Fitnessstudio betreibt eine Kundensoftware mit folgenden Anforderungen:&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;* Ein Mitglied kann mehrere Kurse besuchen.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;* Ein Kurs wird von einem Trainer geleitet.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;* Ein Trainer kann mehrere Kurse leiten.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;* Jedes Mitglied besitzt ein Mitgliedsprofil (ID, Name, Beitrittsdatum).&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;* Jeder Kurs besitzt Attribute wie KursID, Name, Raum, Zeit.&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;Modelliere ein ER-Diagramm und stelle sicher, dass alle n:m- und 1:n-Beziehungen korrekt dargestellt werden. Gib die Primärschlüssel der Entitäten an.&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="250" x="640" as="geometry" />
        </mxCell>
